// count odd numbers

#include <bits/stdc++.h>
using namespace std;

int arr[5] = {3, 8, 1, 7, 2};
int counts=0;
int main(){
    int n=5;
    for (int i=0;i<5;i++){
        if(arr[i]%2!=0)
        counts++;
    }
    cout<<counts;
    return 0;
}

