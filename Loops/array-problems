// find sum

#include <bits/stdc++.h>
using namespace std;

int arr[5] = {3, 8, 1, 7, 2};
int sum=0;
int main(){
    int n=5;
    for (int i=0;i<5;i++){
        sum=sum+arr[i];
    }
    cout<<sum;
    return 0;
}

