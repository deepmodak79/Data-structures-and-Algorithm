// print in reverse

#include <bits/stdc++.h>
using namespace std;

int arr[5] = {3, 8, 1, 7, 2};
int main(){
    int n=5;
    for (int i=n-1;i>=0;i--){
        cout<<arr[i]<<" ";
    }
    return 0;
}

