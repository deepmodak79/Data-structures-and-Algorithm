## 1) Print all elements
#include <bits/stdc++.h>
using namespace std;

int arr[5]={40,10,30,20,50};

int main(){
    for (int i=0;i<5;i++){
        cout<<arr[i]<<" ";
    }
    return 0;
}



## 2) Sum of all elements

#include <bits/stdc++.h>
using namespace std;

int arr[5]={40,10,30,20,50};
int sum=0;
int main(){
    for(int i=0;i<5;i++){
        sum=sum+arr[i];
    }
    cout<<sum;
    return 0;
}

## Find maximum Elements

#include <bits/stdc++.h>
using namespace std;

int arr[5]={20,10,50,30,80};
int mx=arr[0];
int main(){
    for(int i=1;i<5;i++){
        if(mx<arr[i]){
            mx=arr[i];
        }
    }
    cout<<mx;
    return 0;
}


## Count Even Elements
#include <bits/stdc++.h>
using namespace std;

int arr[5]={10,15,20,9,30};
int num=0;
int main(){
    for (int i=0;i<5;i++){
        if(arr[i]%2==0){
            //cout<<arr[i]<<" ";
            num++;
        }
    }
    cout<<num;
    return 0;
}


